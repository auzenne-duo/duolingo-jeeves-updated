[
  {
    "command": [
      "python",
      "./jeeves/scripts/shakira/send_bug_digest_emails.py"
    ],
    "cpu": ${cpu},
    "environment": [
      {
        "name": "PYTHONPATH",
        "value": "/code"
      }
    ],
    "essential": true,
    "image": "${ecr_repo}:${version}",
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "${service}",
        "awslogs-region": "${region}",
        "awslogs-stream-prefix": "${service}",
        "mode": "non-blocking"
      }
    },
    "memory": ${memory},
    "name": "${service}",
    "secrets": ${secrets},
    "ulimits": [
      {
        "hardLimit": 65535,
        "name": "nofile",
        "softLimit": 65535
      }
    ]
  }
]
