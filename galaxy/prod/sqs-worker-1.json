[
  {
    "name": "${service}",
    "image": "${ecr_repo}:${version}",
    "cpu": ${cpu},
    "memory": ${memory},
    "essential": true,
    "ulimits": [{
        "name": "nofile",
        "softLimit": 65535,
        "hardLimit": 65535
    }],
    "environment": ${environment_vars},
    "command": ["python","./jeeves/scripts/index_pipeline_and_spike_detector/sqs_verify_worker.py"],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-region": "${region}",
        "awslogs-group": "${service}",
        "awslogs-stream-prefix": "${service}",
        "mode": "non-blocking"
      }
    }
  }
]
